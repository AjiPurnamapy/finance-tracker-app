# ============================================================
# Finance Tracker Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/finance_tracker

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
# Generate with: openssl rand -hex 16
SECRET_PEPPER=your-pepper-change-this-too

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
APP_NAME="Finance Tracker API"
APP_VERSION="0.1.0"

# --- CORS ---
# JSON array of allowed origins for Flutter app
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- PTS Exchange Rate ---
# Default: 1000 PTS = Rp 10.000 → rate = 10.0
DEFAULT_PTS_TO_IDR_RATE=10.0
MIN_PTS_EXCHANGE=100
